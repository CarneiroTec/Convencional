// ============================================================
// Ponto de Entrada
// ============================================================

Inteiro Início() {
    Grupo g = grupo.crie("Testando Módulo Dados");

    grupo.adicione(&g, testa_crie);
    grupo.adicione(&g, testa_destrua);
    grupo.adicione(&g, testa_destrua_nulo);
    grupo.adicione(&g, testa_copie);
    grupo.adicione(&g, testa_clone);
    grupo.adicione(&g, testa_inicialize);
    grupo.adicione(&g, testa_inicialize_nulo);
    grupo.adicione(&g, testa_limpe);
    grupo.adicione(&g, testa_acessor_ponteiro);
    grupo.adicione(&g, testa_acessor_tamanho);
    grupo.adicione(&g, testa_acessor_base);
    grupo.adicione(&g, testa_acessor_tipo);
    grupo.adicione(&g, testa_acessor_arquivo);
    grupo.adicione(&g, testa_acessor_reserva_caractere);
    grupo.adicione(&g, testa_acessor_tamanho_reserva);
    grupo.adicione(&g, testa_acessor_nome_arquivo);

    grupo.execute(&g);
    grupo.destrua(&g);
    Retorne 0;
}
