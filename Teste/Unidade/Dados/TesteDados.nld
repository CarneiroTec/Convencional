#Inclua "../../Teste.nld"

// ============================================================
// Teste: dados.crie
// ============================================================

Caso testa_crie() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };

    Dados d = dados.crie();

    Se (d.ponteiro != (Vazio*)0 || d.tamanho != 0 || d.arquivo != -1) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: crie não inicializou corretamente";
        Retorne caso;
    }

    caso.mensagem = "Passou: dados.crie";
    Retorne caso;
}

// ============================================================
// Teste: dados.destrua
// ============================================================

Caso testa_destrua() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };

    Dados d = dados.crie();
    d.tamanho = 42;
    d.tipo = 3;
    dados.destrua(&d);

    Se (d.tamanho != 0 || d.tipo != 0) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: destrua não zerou os campos";
        Retorne caso;
    }

    caso.mensagem = "Passou: dados.destrua";
    Retorne caso;
}

Caso testa_destrua_nulo() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };
    dados.destrua((Vazio*)0);
    caso.mensagem = "Passou: dados.destrua com nulo não causa falha";
    Retorne caso;
}

// ============================================================
// Teste: dados.copie (cópia rasa)
// ============================================================

Caso testa_copie() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };

    Dados origem = dados.crie();
    origem.tamanho = 100;
    origem.tipo = 5;
    origem.arquivo = 7;

    Dados destino = dados.crie();
    dados.copie(&destino, &origem);

    Se (destino.tamanho != 100 || destino.tipo != 5 || destino.arquivo != 7) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: copie não copiou os campos";
        Retorne caso;
    }

    // Shallow: ponteiros devem ser os mesmos
    Se (destino.ponteiro != origem.ponteiro) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: copie deve compartilhar ponteiros";
        Retorne caso;
    }

    caso.mensagem = "Passou: dados.copie (cópia rasa)";
    Retorne caso;
}

// ============================================================
// Teste: dados.clone (cópia profunda)
// ============================================================

Caso testa_clone() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };

    Dados origem = dados.crie();
    origem.tamanho = 100;
    origem.tipo = 5;
    origem.arquivo = 7;

    Dados destino = dados.crie();
    dados.clone(&destino, &origem);

    Se (destino.tamanho != 100 || destino.tipo != 5 || destino.arquivo != 7) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: clone não copiou os campos";
        Retorne caso;
    }

    caso.mensagem = "Passou: dados.clone (cópia profunda)";
    Retorne caso;
}

// ============================================================
// Teste: dados.inicialize
// ============================================================

Caso testa_inicialize() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };

    Dados d;
    dados.inicialize(&d);

    Se (d.ponteiro != (Vazio*)0 || d.tamanho != 0 || d.base != (Vazio*)0 ||
        d.tipo != 0 || d.arquivo != -1 || d.reservaCaractere != -1 ||
        d.tamanhoReserva != 0 || d.nomeArquivo != (Vazio*)0) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: inicialize não zerou todos os campos";
        Retorne caso;
    }

    caso.mensagem = "Passou: dados.inicialize";
    Retorne caso;
}

Caso testa_inicialize_nulo() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };
    dados.inicialize((Vazio*)0);
    caso.mensagem = "Passou: dados.inicialize com nulo não causa falha";
    Retorne caso;
}

// ============================================================
// Teste: dados.limpe
// ============================================================

Caso testa_limpe() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };

    Dados d = dados.crie();
    d.tamanho = 100;
    d.arquivo = 5;
    dados.limpe(&d);

    Se (d.tamanho != 0 || d.arquivo != -1) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: limpe não reiniciou os campos";
        Retorne caso;
    }

    caso.mensagem = "Passou: dados.limpe";
    Retorne caso;
}

// ============================================================
// Teste: acessores defina/obtenha
// ============================================================

Caso testa_acessor_ponteiro() {
    Caso caso = { .estado = 1, .arquivo = ARQUIVO, .função = FUNÇÃO, .linha = LINHA, .mensagem = "" };
    Dados d = dados.crie();
    Caractere *val = "teste";
    dados.defina_ponteiro(&d, val);
    Se (dados.obtenha_ponteiro(&d) != val) {
        caso.estado = 0; caso.linha = LINHA;
        caso.mensagem = "Falhou: defina/obtenha_ponteiro"; Retorne caso;
    }
    caso.mensagem = "Passou: dados.defina/obtenha_ponteiro";
    Retorne caso;
}

